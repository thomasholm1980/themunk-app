{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@themunk/core": ["packages/core/index.ts"],
      "@themunk/wearables": ["packages/wearables/index.ts"],
      "@themunk/schemas": ["packages/schemas/index.ts"]
    }
  }
}
